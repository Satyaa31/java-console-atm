{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "SecureBank GUI",
      "request": "launch",
      "mainClass": "com.atm.gui.ATMGuiApp",
      "projectName": "securebank-india-atm",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "prepare-javafx",
      "vmArgs": "--module-path \"${workspaceFolder}/lib/javafx\" --add-modules javafx.controls,javafx.graphics,javafx.base",
      "console": "integratedTerminal",
      "shortenCommandLine": "argfile"
    },
    {
      "type": "java",
      "name": "SecureBank Console",
      "request": "launch",
      "mainClass": "com.atm.main.ATMApplication",
      "projectName": "securebank-india-atm",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "prepare-javafx",
      "console": "integratedTerminal",
      "shortenCommandLine": "argfile"
    }
  ]
}
