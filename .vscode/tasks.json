{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "prepare-javafx",
      "type": "shell",
      "command": "bash scripts/prepare-javafx.sh",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "JAVA_HOME": "/usr/lib/jvm/java-21-openjdk-amd64"
        }
      },
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "build",
      "type": "shell",
      "command": "mvn -q -DskipTests compile dependency:copy-dependencies@copy-javafx",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "JAVA_HOME": "/usr/lib/jvm/java-21-openjdk-amd64"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$javac"
      ]
    },
    {
      "label": "run: SecureBank GUI",
      "type": "shell",
      "command": "bash scripts/run-gui.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "prepare-javafx"
      ],
      "problemMatcher": []
    },
    {
      "label": "run: SecureBank Console",
      "type": "shell",
      "command": "bash scripts/run-console.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "prepare-javafx"
      ],
      "problemMatcher": []
    }
  ]
}
